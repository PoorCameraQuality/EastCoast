# Basic Page Metadata Template:
```typescript
export const metadata: Metadata = {
  title: 'Page Title | Site Name',
  description: 'Compelling description under 160 characters that includes primary keywords and value proposition.',
  keywords: ['primary keyword', 'secondary keyword', 'related terms'],
  openGraph: {
    title: 'Page Title | Site Name',
    description: 'Same as meta description or slightly different for social sharing.',
    type: 'website',
    url: 'https://yourdomain.com/page-path',
    images: [{ url: '/og-image.png', width: 1200, height: 630, alt: 'Descriptive alt text' }],
  },
  twitter: {
    card: 'summary_large_image',
    title: 'Page Title | Site Name',
    description: 'Twitter-optimized description.',
    images: ['/og-image.png'],
  },
  alternates: { canonical: 'https://yourdomain.com/page-path' },
}
```

# Basic Structured Data Template:
```typescript
export function PageStructuredData({ data }: { data: any }) {
  const structuredData = {
    "@context": "https://schema.org",
    "@type": "WebPage", // or Article, Event, etc.
    "name": data.title,
    "description": data.description,
    "url": `https://yourdomain.com/${data.slug}`,
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://yourdomain.com/${data.slug}`
    }
  }

  try {
    const jsonString = JSON.stringify(structuredData).replace(/</g, '\\u003c')
    return (
      <Script
        id={`page-structured-data-${data.slug}`}
        type="application/ld+json"
        dangerouslySetInnerHTML={{ __html: jsonString }}
      />
    )
  } catch (error) {
    console.error('Invalid JSON in PageStructuredData:', error)
    return null
  }
}
```

# Analytics Hook Template:
```typescript
export const useAnalytics = () => {
  const trackEvent = (action: string, category: string, label?: string) => {
    if (typeof window !== 'undefined' && (window as any).gtag) {
      (window as any).gtag('event', action, {
        event_category: category,
        event_label: label,
      })
    }
  }

  const trackPageView = (url: string) => {
    if (typeof window !== 'undefined' && (window as any).gtag) {
      (window as any).gtag('config', process.env.NEXT_PUBLIC_GA_MEASUREMENT_ID, {
        page_path: url,
      })
    }
  }

  return { trackEvent, trackPageView }
}
```