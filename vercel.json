{
  "description": "East Coast Kink Events - Updated deployment trigger",
  "functions": {
    "app/**/*.tsx": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/kinkeducationcenter/:slug*",
      "destination": "/education/:slug*",
      "permanent": true
    },
    {
      "source": "/kinkeducationcenter",
      "destination": "/education/",
      "permanent": true
    },
    {
      "source": "/",
      "has": [
        {
          "type": "query",
          "key": "category"
        }
      ],
      "destination": "/events/",
      "permanent": true
    },
    {
      "source": "/",
      "has": [
        {
          "type": "query",
          "key": "format",
          "value": "amp"
        }
      ],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/:slug",
      "has": [
        {
          "type": "query",
          "key": "format",
          "value": "amp"
        }
      ],
      "destination": "/:slug",
      "permanent": true
    },
    {
      "source": "/:path*",
      "destination": "https://www.eastcoastkinkevents.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "origin-when-cross-origin"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ],
  "build": {
    "env": {
      "DISABLE_VERCEL_FEEDBACK": "true"
    }
  },
  "buildCommand": "npm run build",
  "installCommand": "npm install"
}

