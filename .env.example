# Copy to .env.local and fill in values. Never commit real keys.
# Rotate keys in Supabase Dashboard if they were ever exposed.

# --- Supabase (required for auth / middleware) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: admin API routes, scripts
SUPABASE_SERVICE_ROLE_KEY=

# Optional: direct Postgres URI for `npm run dancecard:apply-migrations` (Supabase Dashboard → Database → URI)
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- Dancecard (optional; required for /dancecard/* API + scripts) ---
# Same Supabase keys as above; dancecard route handlers use the service role only.
# Canonical public origin for dancecard share links (and client copy). Set in Vercel for Preview *and*
# Production if you use branch previews; otherwise copied links use *.vercel.app from VERCEL_URL.
# NEXT_PUBLIC_SITE_URL=https://www.eastcoastkinkevents.com
#
# Local only: skip organizer login for /organizer/dancecard/* (requires `next dev`, NODE_ENV=development).
# DANCECARD_ORGANIZER_DEV_BYPASS=1

# --- Analytics & SEO (public where noted) ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Optional: Google Search Console HTML tag verification string
NEXT_PUBLIC_GSC_VERIFICATION=

# --- Optional structured data / social (public URLs) ---
NEXT_PUBLIC_TWITTER_URL=
NEXT_PUBLIC_INSTAGRAM_URL=

# --- ChatGPT plugin manifest (`/.well-known/ai-plugin.json`) ---
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_PLUGIN_LOGO_URL=

# --- Discovery / SEO rollout (see src/lib/discoveryIndexingEnv.ts and *DiscoveryTier.ts) ---
# NEXT_PUBLIC_DISCOVERY_LIMITED=true
# NEXT_PUBLIC_DISCOVERY_FULL_INDEX=true
# NEXT_PUBLIC_VENDOR_DISCOVERY_FULL_INDEX=true
# NEXT_PUBLIC_DUNGEON_DISCOVERY_FULL_INDEX=true
# NEXT_PUBLIC_SWING_DISCOVERY_FULL_INDEX=true
# NEXT_PUBLIC_BLOG_PROGRAMMATIC_FULL_INDEX=true

# --- Data source preference (unified static + DB) ---
# UNIFIED_EVENTS_PREFER_DB=true
# UNIFIED_VENDORS_PREFER_DB=true

# --- Server-only integrations ---
BUTTONDOWN_API_KEY=
EMAIL_WEBHOOK_URL=
RESEND_API_KEY=

# --- Vercel / app ---
# DISABLE_VERCEL_FEEDBACK is set in next.config.js env block
