# Copy to .env.local and fill in values. Never commit real keys.
# Rotate keys in Supabase Dashboard if they were ever exposed.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: admin API routes (e.g. submissions approval). Not exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# GA4 (public; same ID is visible in gtag in the browser). Set on Vercel/hosting for production.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-YRXEJ4E72Y

# Optional: when "true", all /bdsm-events/* pages can be indexed (subject to thin-content rules).
# When unset, only tier allowlisted paths (see src/lib/discoveryTier.ts) are indexable.
# NEXT_PUBLIC_DISCOVERY_FULL_INDEX=true

# After migrating static events.js → Supabase, set "true" so DB rows override duplicates (same slug).
# UNIFIED_EVENTS_PREFER_DB=true
