<svg width="200" height="200" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="200" height="200" fill="#1F2937" rx="20"/>
  
  <!-- Conference/party people -->
  <!-- Person 1 (left) -->
  <path d="M50 70 C 45 70, 40 75, 40 80 C 40 85, 45 90, 50 90 C 55 90, 60 85, 60 80 C 60 75, 55 70, 50 70 Z" fill="#9CA3AF"/>
  <path d="M50 90 L 50 130 L 60 130 L 60 90 Z" fill="#9CA3AF"/>
  <path d="M50 100 L 40 110 L 40 120 L 50 110 Z" fill="#9CA3AF"/>
  <path d="M60 100 L 70 110 L 70 120 L 60 110 Z" fill="#9CA3AF"/>
  
  <!-- Person 2 (center) -->
  <path d="M90 60 C 85 60, 80 65, 80 70 C 80 75, 85 80, 90 80 C 95 80, 100 75, 100 70 C 100 65, 95 60, 90 60 Z" fill="#9CA3AF"/>
  <path d="M90 80 L 90 120 L 100 120 L 100 80 Z" fill="#9CA3AF"/>
  <path d="M90 90 L 80 100 L 80 110 L 90 100 Z" fill="#9CA3AF"/>
  <path d="M100 90 L 110 100 L 110 110 L 100 100 Z" fill="#9CA3AF"/>
  
  <!-- Person 3 (right) -->
  <path d="M130 70 C 125 70, 120 75, 120 80 C 120 85, 125 90, 130 90 C 135 90, 140 85, 140 80 C 140 75, 135 70, 130 70 Z" fill="#9CA3AF"/>
  <path d="M130 90 L 130 130 L 140 130 L 140 90 Z" fill="#9CA3AF"/>
  <path d="M130 100 L 120 110 L 120 120 L 130 110 Z" fill="#9CA3AF"/>
  <path d="M140 100 L 150 110 L 150 120 L 140 110 Z" fill="#9CA3AF"/>
  
  <!-- Party elements -->
  <circle cx="30" cy="40" r="4" fill="#F59E0B"/>
  <circle cx="170" cy="35" r="4" fill="#EF4444"/>
  <circle cx="25" cy="170" r="4" fill="#10B981"/>
  <circle cx="175" cy="180" r="4" fill="#8B5CF6"/>
  
  <!-- Conference stage/platform -->
  <rect x="40" y="140" width="120" height="8" fill="#374151" rx="2"/>
  
  <!-- KinkyCon Text -->
  <text x="100" y="175" font-family="Arial, sans-serif" font-size="16" font-weight="bold" text-anchor="middle" fill="#F3F4F6">KinkyCon</text>
  
  <!-- Conference indicator -->
  <text x="100" y="190" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" fill="#9CA3AF">Conference</text>
</svg>
