<svg width="200" height="200" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="200" height="200" fill="#1F2937" rx="20"/>
  
  <!-- Party people with wine glasses -->
  <!-- Person 1 (left) with wine glass -->
  <path d="M60 80 C 55 80, 50 85, 50 90 C 50 95, 55 100, 60 100 C 65 100, 70 95, 70 90 C 70 85, 65 80, 60 80 Z" fill="#9CA3AF"/>
  <path d="M60 100 L 60 140 L 70 140 L 70 100 Z" fill="#9CA3AF"/>
  <path d="M60 110 L 50 120 L 50 130 L 60 120 Z" fill="#9CA3AF"/>
  <path d="M70 110 L 80 120 L 80 130 L 70 120 Z" fill="#9CA3AF"/>
  
  <!-- Wine glass for person 1 -->
  <path d="M75 85 L 75 115 L 80 115 L 80 95 L 85 95 L 85 115 L 90 115 L 90 85 Z" fill="#F59E0B" opacity="0.8"/>
  
  <!-- Person 2 (right) with whip -->
  <path d="M130 70 C 125 70, 120 75, 120 80 C 120 85, 125 90, 130 90 C 135 90, 140 85, 140 80 C 140 75, 135 70, 130 70 Z" fill="#9CA3AF"/>
  <path d="M130 90 L 130 130 L 140 130 L 140 90 Z" fill="#9CA3AF"/>
  <path d="M130 100 L 120 110 L 120 120 L 130 110 Z" fill="#9CA3AF"/>
  <path d="M140 100 L 150 110 L 150 120 L 140 110 Z" fill="#9CA3AF"/>
  
  <!-- Whip for person 2 -->
  <path d="M145 80 L 165 90 L 145 100" stroke="#8B5CF6" stroke-width="3" fill="none"/>
  
  <!-- Person 3 (center) -->
  <path d="M95 90 C 90 90, 85 95, 85 100 C 85 105, 90 110, 95 110 C 100 110, 105 105, 105 100 C 105 95, 100 90, 95 90 Z" fill="#9CA3AF"/>
  <path d="M95 110 L 95 150 L 105 150 L 105 110 Z" fill="#9CA3AF"/>
  <path d="M95 120 L 85 130 L 85 140 L 95 130 Z" fill="#9CA3AF"/>
  <path d="M105 120 L 115 130 L 115 140 L 105 130 Z" fill="#9CA3AF"/>
  
  <!-- Party elements -->
  <circle cx="40" cy="50" r="4" fill="#F59E0B"/>
  <circle cx="160" cy="40" r="4" fill="#EF4444"/>
  <circle cx="35" cy="170" r="4" fill="#10B981"/>
  <circle cx="165" cy="180" r="4" fill="#8B5CF6"/>
  
  <!-- Wine bottle -->
  <rect x="85" y="155" width="30" height="20" fill="#F59E0B" opacity="0.8" rx="2"/>
  
  <!-- Whips and Wine Text -->
  <text x="100" y="185" font-family="Arial, sans-serif" font-size="14" font-weight="bold" text-anchor="middle" fill="#F3F4F6">Whips & Wine</text>
</svg>
