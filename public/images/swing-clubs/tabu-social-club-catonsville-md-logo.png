<script>
const fabButton332 = document.getElementById("fab332");
const optionsList332 = document.getElementById("options332");
const fabContainer332 = document.querySelector(".fab-container");

let isFabOpen332 = false;

fabButton332.addEventListener("click", () => {
    if (isFabOpen332) {
        // Close options
        optionsList332.classList.remove("active");

        // Add event listener to detect when the animation is finished
        optionsList332.addEventListener("animationend", () => {
            optionsList332.style.display = "none";
        }, { once: true });
    } else {
        // Open options
        optionsList332.style.display = "block";
        optionsList332.classList.add("active");
    }

    isFabOpen332 = !isFabOpen332;
});
</script>
