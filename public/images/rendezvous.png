<svg width="200" height="200" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="200" height="200" fill="#1F2937" rx="20"/>
  
  <!-- Meeting/party people -->
  <!-- Person 1 (left) -->
  <path d="M50 80 C 45 80, 40 85, 40 90 C 40 95, 45 100, 50 100 C 55 100, 60 95, 60 90 C 60 85, 55 80, 50 80 Z" fill="#9CA3AF"/>
  <path d="M50 100 L 50 140 L 60 140 L 60 100 Z" fill="#9CA3AF"/>
  <path d="M50 110 L 40 120 L 40 130 L 50 120 Z" fill="#9CA3AF"/>
  <path d="M60 110 L 70 120 L 70 130 L 60 120 Z" fill="#9CA3AF"/>
  
  <!-- Person 2 (right) -->
  <path d="M130 80 C 125 80, 120 85, 120 90 C 120 95, 125 100, 130 100 C 135 100, 140 95, 140 90 C 140 85, 135 80, 130 80 Z" fill="#9CA3AF"/>
  <path d="M130 100 L 130 140 L 140 140 L 140 100 Z" fill="#9CA3AF"/>
  <path d="M130 110 L 120 120 L 120 130 L 130 120 Z" fill="#9CA3AF"/>
  <path d="M140 110 L 150 120 L 150 130 L 140 120 Z" fill="#9CA3AF"/>
  
  <!-- Person 3 (center) -->
  <path d="M90 70 C 85 70, 80 75, 80 80 C 80 85, 85 90, 90 90 C 95 90, 100 85, 100 80 C 100 75, 95 70, 90 70 Z" fill="#9CA3AF"/>
  <path d="M90 90 L 90 130 L 100 130 L 100 90 Z" fill="#9CA3AF"/>
  <path d="M90 100 L 80 110 L 80 120 L 90 110 Z" fill="#9CA3AF"/>
  <path d="M100 100 L 110 110 L 110 120 L 100 110 Z" fill="#9CA3AF"/>
  
  <!-- Connection lines between people -->
  <path d="M60 120 L 90 120" stroke="#8B5CF6" stroke-width="2" opacity="0.6"/>
  <path d="M100 120 L 130 120" stroke="#8B5CF6" stroke-width="2" opacity="0.6"/>
  
  <!-- Party elements -->
  <circle cx="40" cy="50" r="4" fill="#F59E0B"/>
  <circle cx="160" cy="40" r="4" fill="#EF4444"/>
  <circle cx="35" cy="170" r="4" fill="#10B981"/>
  <circle cx="165" cy="180" r="4" fill="#8B5CF6"/>
  
  <!-- Meeting table/platform -->
  <rect x="40" y="145" width="120" height="6" fill="#374151" rx="2"/>
  
  <!-- Rendezvous Text -->
  <text x="100" y="175" font-family="Arial, sans-serif" font-size="16" font-weight="bold" text-anchor="middle" fill="#F3F4F6">Rendezvous</text>
  
  <!-- Meeting indicator -->
  <text x="100" y="190" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" fill="#9CA3AF">Meeting</text>
</svg>
